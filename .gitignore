# =====================================================================
# Simulation output (large, regenerated)
# =====================================================================
output/
vtk_*/
*.pvd
*.vti
*.vtp
*.vtu
*.h5
*.xdmf
*.npz

# Per-run provenance + checkpoints
**/config/run_manifest.json
**/checkpoints/
*.ckpt

# Sweep outputs — push code, papers, figures, and small per-cell summaries;
# block ALL bulk regenerable data (VTK lattice snapshots + .npz time series).
# Re-running the sim regenerates them.
#
# Per user instruction: "dont push npz and vtk" — bulk simulation output
# stays local. We keep small JSON manifests, CSV summaries, and figures.
research/**/sweep_production.log
research/**/*.log

# Allow run_manifest.json (provenance) and per-cell config under research/.
!research/**/config/
!research/**/config/run_manifest.json

# Bulk LBM VTK output is already blocked by the global *.vti/*.vtp/*.pvd
# rules above; the global *.npz rule blocks history.npz / sweep_results.npz.
# No unignore rules — keep the repo light.

